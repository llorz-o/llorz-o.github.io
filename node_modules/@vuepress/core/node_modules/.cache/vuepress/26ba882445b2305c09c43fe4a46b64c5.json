oveItem('reco-theme')\r\n        classes.remove(`reco-theme-${theme}`)\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"stylus\">\r\n@require '../../styles/recoConfig.styl'\r\n\r\n.color-theme-options {\r\n\tdisplay: flex;\r\n\tflex-wrap wrap\r\n\tli {\r\n\t\twidth: 20%;\r\n\t\ttext-align: center;\r\n\t\ta {\r\n\t\t\twidth: 15px;\r\n\t\t\theight: 15px;\r\n\t\t\tborder-radius: $borderRadius\r\n\t\t\t&.default-theme {\r\n\t\t\t\tbackground-color: $accentColor;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n}\r\n</style>\r\n"],"sourceRoot":"node_modules/vuepress-theme-reco/components/Theme"}]}