    this.isMoving = false\r\n        } else {\r\n          window.scrollTo(0, next)\r\n        }\r\n        i++\r\n      }, 16.7)\r\n    },\r\n    easeInOutQuad (t, b, c, d) {\r\n      if ((t /= d / 2) < 1) return c / 2 * t * t + b\r\n      return -c / 2 * (--t * (t - 2) - 1) + b\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"stylus\" scoped>\r\n@require './iconfont.css'\r\n  .back-to-ceiling\r\n    position: fixed;\r\n    display: inline-block;\r\n    text-align: center;\r\n    cursor: pointer;\r\n    &::hover\r\n      background: #d5dbe7;\r\n    i\r\n      font-size 1.6rem\r\n      color $accentColor\r\n  .fade-enter-active,\r\n  .fade-leave-active {\r\n    transition: all .5s;\r\n  }\r\n  .fade-enter,\r\n  .fade-leave-to {\r\n    opacity: 0\r\n    transform translateY(120px)\r\n  }\r\n</style>\r\n"],"sourceRoot":"node_modules/@vuepress-reco/vuepress-plugin-back-to-top/bin"}]}