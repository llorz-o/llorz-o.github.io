A,CAAA,GAAA,EAAA,GAAA,KAAA;;AACA,WAAA,IAAA,CAAA,GAAA,CAAA,EAAA,MAAA,GAAA,KAAA,CAAA,MAAA,EAAA,CAAA,GAAA,MAAA,EAAA,CAAA,EAAA,EAAA;AACA,YAAA,IAAA,GAAA,KAAA,CAAA,CAAA,CAAA;AACA,YAAA,YAAA,GAAA,KAAA,UAAA,CAAA,IAAA,CAAA,WAAA,CAAA,IAAA,EAAA,MAAA,CAAA;AACA,YAAA,KAAA,WAAA,CAAA,YAAA,CAAA,EAAA,KAAA,WAAA,CAAA,YAAA,EAAA,IAAA,CAAA,IAAA,EAAA,KACA;AACA,eAAA,WAAA,CAAA,YAAA,IAAA,CAAA,IAAA,CAAA;AACA;AACA;;AAEA,WAAA,IAAA,GAAA,IAAA,KAAA,WAAA,EAAA;AACA,YAAA,IAAA,GAAA,KAAA,WAAA,CAAA,GAAA,CAAA;;AACA,aAAA,aAAA,CAAA,IAAA;;AACA,aAAA,cAAA,CAAA,OAAA,CAAA;AACA,UAAA,IAAA,EAAA,GADA;AAEA,UAAA,IAAA,EAAA;AAFA,SAAA;AAIA;AACA,KAxBA;AAyBA,IAAA,UAzBA,sBAyBA,IAzBA,EAyBA;AACA,UAAA,MAAA,GAAA,IAAA,IAAA,CAAA,IAAA,EAAA,MAAA,EAAA;AACA,aAAA,IAAA,IAAA,CAAA,CAAA,IAAA,IAAA,CAAA,MAAA,CAAA,GAAA,IAAA,IAAA,GAAA,IAAA,EAAA,WAAA,GAAA,OAAA,CAAA,IAAA,EAAA,GAAA,EAAA,OAAA,CAAA,YAAA,EAAA,EAAA,EAAA,OAAA,CAAA,IAAA,EAAA,GAAA,CAAA;AACA,KA5BA;AA6BA;AACA,IAAA,UA9BA,sBA8BA,IA9BA,EA8BA,IA9BA,EA8BA;AACA,MAAA,IAAA,GAAA,KAAA,UAAA,CAAA,IAAA,CAAA;AACA,UAAA,OAAA,GAAA,IAAA,IAAA,CAAA,IAAA,CAAA;AACA,UAAA,IAAA,GAAA,OAAA,CAAA,WAAA,EAAA;AACA,UAAA,GAAA,GAAA,OAAA,CAAA,QAAA,KAAA,CAAA;AACA,UAAA,GAAA,GAAA,OAAA,CAAA,OAAA,EAAA;AACA,UAAA,IAAA,IAAA,MAAA,EAAA,OAAA,IAAA,CAAA,KACA,iBAAA,GAAA,cAAA,GAAA;AACA,KAtCA;AAuCA;AACA,IAAA,EAxCA,cAwCA,GAxCA,EAwCA;AACA,WAAA,OAAA,CAAA,IAAA,CAAA;AAAA,QAAA,IAAA,EAAA;AAAA,OAAA;AACA,KA1CA;AA2CA;AACA,IAAA,WA5CA,uBA4CA,IA5CA,EA4CA;AACA,aAAA,QAAA,CAAA,IAAA,IAAA,CAAA,IAAA,CAAA,WAAA,CAAA,IAAA,EAAA,OAAA,EAAA,CAAA;AACA;AA9CA;AA5BA,CAAA","sourcesContent":["<template>\r\n<div>\r\n  <Common :sidebar=\"false\" :isComment=\"false\">\r\n    <ul class=\"timeline-wrapper\">\r\n      <li class=\"desc\">Yesterday Once More!</li>\r\n      <li v-for=\"(item, index) in formatPagesArr\" :key=\"index\">\r\n        <h3 class=\"year\">{{item.year}}</h3>\r\n        <ul class=\"year-wrapper\">\r\n          <li v-for=\"(subItem, subIndex) in item.data\" :key=\"subIndex\">\r\n            <span class=\"date\">{{dateFormat(subItem.frontmatter.date)}}</span>\r\n            <span class=\"title\" @click=\"go(subItem.path)\">{{subItem.title}}</span>\r\n          </li>\r\n        </ul>\r\n      </li>\r\n    </ul>\r\n  </Common>\r\n</div>\r\n\r\n</template>\r\n\r\n<script>\r\nimport Common from '@theme/components/Common.vue'\r\nimport mixin from '@theme/mixins/index.js'\r\n\r\nexport default {\r\n  mixins: [mixin],\r\n  name: 'TimeLine',\r\n  components: { Common },\r\n  data () {\r\n    return {\r\n      pages: [],\r\n      tags: [],\r\n      currentTag: '',\r\n      currentPage: 1,\r\n      formatPages: {},\r\n      formatPagesArr: []\r\n    }\r\n  },\r\n  props: {\r\n    tag: {\r\n      type: String,\r\n      default: ''\r\n    }\r\n  },\r\n  computed: {\r\n    trueCurrentTag () {\r\n      return this.currentTag\r\n    }\r\n  },\r\n  created () {\r\n    this.getPages()\r\n  },\r\n  methods: {\r\n    // 根据分类获取页面数据\r\n    getPages (tag) {\r\n      let pages = this.$site.pages\r\n      pages = this._filterPostData(pages)\r\n      // reverse()是为了按时间最近排序排序\r\n      this.pages = pages.length == 0 ? [] : pages\r\n      for (let i = 0, length = pages.length; i < length; i++) {\r\n        const page = pages[i]\r\n        const pageDateYear = this.dateFormat(page.frontmatter.date, 'year')\r\n        if (this.formatPages[pageDateYear]) this.formatPages[pageDateYear].push(page)\r\n        else {\r\n          this.formatPages[pageDateYear] = [page]\r\n        }\r\n      }\r\n\r\n      for (const key in this.formatPages) {\r\n        const data = this.formatPages[key]\r\n        this._sortPostData(data)\r\n        this.formatPagesArr.unshift({\r\n          year: key,\r\n          data\r\n        })\r\n      }\r\n    },\r\n    renderTime (date) {\r\n      var dateee = new Date(date).toJSON()\r\n      return new Date(+new Date(dateee) + 8 * 3600 * 1000).toISOString().replace(/T/g, ' ').replace(/\\.[\\d]{3}Z/, '').replace(/-/g, '/')\r\n    },\r\n    // 时间格式化\r\n    dateFormat (date, type) {\r\n      date = this.renderTime(date)\r\n      const dateObj = new Date(date)\r\n      const year = dateObj.getFullYear()\r\n      const mon = dateObj.getMonth() + 1\r\n      const day = dateObj.getDate()\r\n      if (type == 'year') return year\r\n      else return `${mon}-${day}`\r\n    },\r\n    // 跳转\r\n    go (url) {\r\n      this.$router.push({ path: url })\r\n    },\r\n    // 获取时间的数字类型\r\n    _getTimeNum (date) {\r\n      return parseInt(new Date(date.frontmatter.date).getTime())\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"stylus\" scoped>\r\n@require '../styles/wrapper.styl'\r\n\r\n.timeline-wrapper\r\n  box-sizing border-box\r\n  max-width: 740px;\r\n  margin: 4rem auto;\r\n  position relative\r\n  list-style none\r\n  &::after {\r\n    content: \" \";\r\n    position: absolute;\r\n    top: 14px;\r\n    left: 0;\r\n    margin-left: -2px;\r\n    width: 4px;\r\n    height: 100%;\r\n    background: #f5f5f5;\r\n  }\r\n  .desc, .year {\r\n    position: relative;\r\n    color #666\r\n    font-size 16px\r\n    &:before {\r\n      content: \" \";\r\n      position: absolute;\r\n      z-index 2;\r\n      left: -19px;\r\n      top: 50%;\r\n      margin-left: -4px;\r\n      margin-top: -4px;\r\n      width: 8px;\r\n      height: 8px;\r\n      background: #ddd;\r\n      border-radius: 50%;\r\n    }\r\n  }\r\n  .year {\r\n    margin: 80px 0 0px;\r\n    color #555\r\n    font-weight: 700;\r\n    font-size 26px\r\n  }\r\n  .year-wrapper {\r\n    padding-left 0!important\r\n    li {\r\n      display flex\r\n      padding 30px 0 10px\r\n      list-style none\r\n      border-bottom: 1px dashed #ccc;\r\n      position relative\r\n      &:hover {\r\n        .date {\r\n          color $accentColor\r\n          &::before {\r\n            background $accentColor\r\n          }\r\n        }\r\n        .title {\r\n          color $accentColor\r\n        }\r\n      }\r\n      .date {\r\n        width 40px\r\n        line-height 30px\r\n        color: #555;\r\n        font-size 12px\r\n        &::before {\r\n          content: \" \";\r\n          position: absolute;\r\n          left: -19px;\r\n          top: 41px;\r\n          width: 6px;\r\n          height: 6px;\r\n          margin-left: -4px;\r\n          background: #ddd;\r\n          border-radius: 50%;\r\n          border: 1px solid #fff;\r\n          z-index 2\r\n        }\r\n      }\r\n      .title {\r\n        line-height 30px\r\n        color: #555;\r\n        font-size 16px\r\n        cursor pointer\r\n      }\r\n    }\r\n  }\r\n@media (max-width: $MQMobile)\r\n  .timeline-wrapper\r\n    margin: 0 1.2rem;\r\n</style>\r\n"],"sourceRoot":"node_modules/vuepress-theme-reco/layouts"}]}