}`))\r\n\r\n      if (moveClass) {\r\n        classes.add(`reco-theme-${theme}`)\r\n        localStorage.setItem('reco-theme', theme)\r\n      } else {\r\n        localStorage.removeItem('reco-theme')\r\n        classes.remove(`reco-theme-${theme}`)\r\n      }\r\n    }\r\n  }\r\n}\r\n"]}]}