AAAA,MAAM,CAACK,CAAP,GAAW,KAAKA,CAAhB;AACAL,QAAAA,MAAM,CAACO,KAAP,GAAe,KAAKA,KAApB;AACAP,QAAAA,MAAM,CAACM,MAAP,GAAgB,KAAKA,MAAL,GAAc,GAA9B;AACAN,QAAAA,MAAM,CAACc,UAAP;AACAd,QAAAA,MAAM,CAACU,SAAP,GAAmB,KAAKA,SAAxB,CAPwB,CASxB;;AACAX,QAAAA,QAAQ,CAAC0C,GAAT,CAAazC,MAAb;AACH,OAd4B,CAe7B;;;AACAD,MAAAA,QAAQ,CAAC2C,MAAT,CAAgB,IAAhB;AACH;AACJ,GA/Ec;AAiFfrB,EAAAA,GAAG,EAAE,eAAW;AACZ,QAAI,KAAKf,MAAL,GAAc,GAAlB,EAAuB;AACnBP,MAAAA,QAAQ,CAAC2C,MAAT,CAAgB,IAAhB;AACH;AACJ;AArFc,CAAnB;;AAwFA,IAAIC,gBAAgB,GAAG,SAAnBA,gBAAmB,GAAW;AAC9B,OAAK5C,QAAL,GAAgB,EAAhB;AACA,OAAKD,MAAL,GAAcA,MAAd;AACH,CAHD;;AAKA6C,gBAAgB,CAAC3B,SAAjB,GAA6B;AACzByB,EAAAA,GAAG,EAAE,aAASzC,MAAT,EAAiB;AAClB,SAAKD,QAAL,CAAc6C,IAAd,CAAmB5C,MAAnB;AACH,GAHwB;AAKzB;AACAiB,EAAAA,OAAO,EAAE,mBAAW;AAChB,SAAK,IAAI4B,CAAT,IAAc,KAAK9C,QAAnB,EAA6B;AACzB,WAAKA,QAAL,CAAc8C,CAAd,EAAiB5B,OAAjB;AACH;AACJ,GAVwB;AAYzByB,EAAAA,MAAM,EAAE,gBAAS1C,MAAT,EAAiB;AACrB,SAAK,IAAI6C,CAAT,IAAc,KAAK9C,QAAnB;AACI,UAAI,KAAKA,QAAL,CAAc8C,CAAd,MAAqB7C,MAAzB,EAAiC,KAAKD,QAAL,CAAc+C,MAAd,CAAqBD,CAArB,EAAwB,CAAxB;AADrC;AAEH;AAfwB,CAA7B;AAkBA,eAAe,SAASE,IAAT,CAAcC,QAAd,EAAwB;AACnCpD,EAAAA,KAAK,GAAGqD,MAAM,CAACC,UAAf;AACArD,EAAAA,MAAM,GAAGoD,MAAM,CAACE,WAAhB;AACArD,EAAAA,MAAM,GAAGsD,QAAQ,CAACC,cAAT,CAAwBL,QAAxB,CAAT;AACAlD,EAAAA,MAAM,CAACF,KAAP,GAAeA,KAAf;AACAE,EAAAA,MAAM,CAACD,MAAP,GAAgBA,MAAhB,CALmC,CAOnC;;AACA,MAAIyC,CAAC,GAAG,IAAI9B,IAAI,CAAC4B,MAAL,KAAgB,CAA5B,CARmC,CAUnC;;AACA,MAAIkB,aAAa,GAAG1D,KAAK,GAAG,EAA5B,CAXmC,CAanC;;AACAG,EAAAA,QAAQ,GAAG,IAAI4C,gBAAJ,EAAX;;AAEA,OAAK,IAAIH,CAAC,GAAG,CAAb,EAAgBA,CAAC,GAAGF,CAApB,EAAuBE,CAAC,EAAxB,EAA4B;AACxBxC,IAAAA,MAAM,GAAG,IAAIC,MAAJ,EAAT,CADwB,CAExB;AACA;;AACAD,IAAAA,MAAM,CAACI,CAAP,GAAWR,KAAK,GAAG,CAAR,GAAY0D,aAAZ,GAA6Bd,CAAC,GAAG,CAAJ,GAAQc,aAAT,GAA0BhB,CAAjE;AACAtC,IAAAA,MAAM,CAACM,MAAP,GAAgBgD,aAAhB,CALwB,CAOxB;;AACAvD,IAAAA,QAAQ,CAAC0C,GAAT,CAAazC,MAAb;AACH;;AAED,MAAIuD,QAAQ,GAAGC,WAAW,CAAC,YAAW;AAClC;AACAzD,IAAAA,QAAQ,CAACkB,OAAT;;AACA,QAAIlB,QAAQ,CAACA,QAAT,CAAkB0D,MAAlB,IAA4B,CAAhC,EAAmC;AAC/BC,MAAAA,aAAa,CAACH,QAAD,CAAb;AACH;AACJ,GANyB,EAMvB,EANuB,CAA1B;AAOH","sourcesContent":["// Author: wukai\r\n// Time:2015-10-04\r\n\r\nvar width, height, canvas,branches,branch;\r\n\r\nvar Branch = function() {\r\n    this.canvas = canvas;\r\n    this.context = canvas.getContext(\"2d\");\r\n    this.x = canvas.width / 2;\r\n    this.y = canvas.height;\r\n    this.radius = 10;\r\n    this.angle = Math.PI / 2;\r\n\r\n    this.fillStyle = \"#e6f7ff\";\r\n    this.shadowColor = \"#e6fffb\";\r\n    this.shadowBlur = 2;\r\n\r\n    this.speed = width / 500;\r\n    this.generation = 0;\r\n    this.distance = 0;\r\n};\r\n\r\nBranch.prototype = {\r\n    // 主要的处理过程发生在这里\r\n    process: function() {\r\n        // 在当前的坐标处画出一个圆形\r\n        this.draw();\r\n        // 把当前的branch继续向上延伸一部分\r\n        this.iterate();\r\n        this.split();\r\n        this.die();\r\n    },\r\n\r\n    draw: function() {\r\n        var context = this.context;\r\n        context.save();\r\n        context.fillStyle = this.fillStyle;\r\n        context.shadowColor = this.shadowColor;\r\n        context.shadowBlur = this.shadowBlur;\r\n        context.beginPath();\r\n        context.moveTo(this.x, this.y);\r\n        // 图形是依靠在各个坐标处画出的圆形组合而成\r\n        context.arc(this.x, this.y, this.radius, 0, 2 * Math.PI, true);\r\n        context.closePath();\r\n        context.fill();\r\n        context.restore();\r\n    },\r\n\r\n    iterate: function() {\r\n        var deltaX = this.speed * Math.cos(this.angle);\r\n        var deltaY = -this.speed * Math.sin(this.angle);\r\n\r\n        // 利用speed控制需要向上延伸的距离\r\n        this.x += deltaX;\r\n        this.y += deltaY;\r\n        // 根据当前是第几代，减小半径值\r\n        this.radius *= 0.99 - this.generation / 250;\r\n\r\n        // 求出距离的增量\r\n        var deltaDistance = Math.sqrt(\r\n            Math.pow(deltaX, 2) + Math.pow(deltaY, 2)\r\n        );\r\n\r\n        // distance指的是当前的这一段树枝的长度\r\n        this.distance += deltaDistance;\r\n\r\n        // 控制speed的大小，使绘图时不至于在两个圆之间出现空白\r\n        if (this.speed > this.radius * 2) {\r\n            this.speed = this.radius * 2;\r\n        }\r\n\r\n        // 产生一个范围在（-0.1, 0.1)之间的随机数,对角度进行一个偏转\r\n        this.angle += Math.random() / 5 - 1 / 5 / 2;\r\n    },\r\n\r\n    split: function() {\r\n        var splitChance = 0;\r\n        // 树干部分，长度大于画面高度1/5时开始分叉\r\n        if (this.generation == 1) splitChance = this.distance / height - 0.2;\r\n        // 树枝部分\r\n        else if (this.generation < 3)\r\n            splitChance = this.distance / height - 0.1;\r\n\r\n        if (Math.random() < splitChance) {\r\n            // 下一代生成n个树枝\r\n            var n = 2 + Math.round(Math.random() * 3);\r\n            for (var i = 0; i < n; i++) {\r\n                var branch = new Branch();\r\n                branch.x = this.x;\r\n                branch.y = this.y;\r\n                branch.angle = this.angle;\r\n                branch.radius = this.radius * 0.9;\r\n                branch.generation++;\r\n                branch.fillStyle = this.fillStyle;\r\n\r\n                // 将branch加入到集合中去\r\n                branches.add(branch);\r\n            }\r\n            // 将父代branch删去\r\n            branches.remove(this);\r\n        }\r\n    },\r\n\r\n    die: function() {\r\n        if (this.radius < 0.5) {\r\n            branches.remove(this);\r\n        }\r\n    }\r\n};\r\n\r\nvar BranchCollection = function() {\r\n    this.branches = [];\r\n    this.canvas = canvas;\r\n};\r\n\r\nBranchCollection.prototype = {\r\n    add: function(branch) {\r\n        this.branches.push(branch);\r\n    },\r\n\r\n    // 依次处理集合内的每一个元素\r\n    process: function() {\r\n        for (var b in this.branches) {\r\n            this.branches[b].process();\r\n        }\r\n    },\r\n\r\n    remove: function(branch) {\r\n        for (var b in this.branches)\r\n            if (this.branches[b] === branch) this.branches.splice(b, 1);\r\n    }\r\n};\r\n\r\nexport default function init(selector) {\r\n    width = window.innerWidth;\r\n    height = window.innerHeight;\r\n    canvas = document.getElementById(selector);\r\n    canvas.width = width;\r\n    canvas.height = height;\r\n\r\n    // 设置初始的数量\r\n    var n = 2 + Math.random() * 3;\r\n\r\n    // 设定初始的半径大小\r\n    var initialRadius = width / 50;\r\n\r\n    // 新建一个集合用于放置所有的branch\r\n    branches = new BranchCollection();\r\n\r\n    for (var i = 0; i < n; i++) {\r\n        branch = new Branch();\r\n        // 以canvas的中点为基准，左右各占一个initialRadius的宽度\r\n        // 根据序号i算出初始x坐标\r\n        branch.x = width / 2 - initialRadius + (i * 2 * initialRadius) / n;\r\n        branch.radius = initialRadius;\r\n\r\n        // 将新的branch加入集合中去\r\n        branches.add(branch);\r\n    }\r\n\r\n    var interval = setInterval(function() {\r\n        // 对集合内的每个元素依次进行处理\r\n        branches.process();\r\n        if (branches.branches.length == 0) {\r\n            clearInterval(interval);\r\n        }\r\n    }, 20);\r\n}\r\n"]}]}