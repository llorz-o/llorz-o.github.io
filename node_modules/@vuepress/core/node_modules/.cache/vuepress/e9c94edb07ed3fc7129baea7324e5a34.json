KAAA,UAAA;AAEA,WAAA,cAAA,CAAA,UAAA;AACA;AACA,GA5BA;AA8BA,EAAA,OA9BA,qBA8BA;AACA,SAAA,QAAA,GAAA,IAAA;AACA,GAhCA;AAkCA,EAAA,OAAA,EAAA;AAEA,IAAA,QAFA;AAAA;AAAA;AAAA,+CAEA,UAFA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,uBAGA,KAAA,cAAA,CAAA,UAAA,CAHA;;AAAA;AAIA,gBAAA,MAAA,CAAA,QAAA,CAAA,CAAA,EAAA,CAAA;;AAJA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;;AAAA;AAAA;AAAA;;AAAA;AAAA;AAOA;AACA,IAAA,cARA,0BAQA,UARA,EAQA;AACA,WAAA,UAAA,GAAA,UAAA;AAEA,UAAA,KAAA,GAAA,EAAA;;AACA,UAAA,UAAA,KAAA,IAAA,EAAA;AACA,QAAA,KAAA,GAAA,KAAA,KAAA,CAAA,GAAA,CAAA,UAAA,EAAA,KAAA;;AACA,aAAA,aAAA,CAAA,KAAA;AACA,OAHA,MAGA;AACA,QAAA,KAAA,GAAA,KAAA,WAAA;AACA,OATA,CAWA;;;AACA,WAAA,KAAA,GAAA,KAAA,CAAA,MAAA,IAAA,CAAA,GAAA,EAAA,GAAA,KAAA;;AAEA,WAAA,QAAA,CAAA,CAAA;AACA,KAvBA;AAyBA,IAAA,aAzBA,yBAyBA,GAzBA,EAyBA;AACA,WAAA,KAAA,CAAA,YAAA,EAAA,GAAA;AACA,KA3BA;AA6BA,IAAA,cA7BA,0BA6BA,IA7BA,EA6BA;AACA,WAAA,QAAA,CAAA,IAAA;;AACA,MAAA,UAAA,CAAA,YAAA;AACA,QAAA,MAAA,CAAA,QAAA,CAAA,CAAA,EAAA,CAAA;AACA,OAFA,EAEA,GAFA,CAAA;AAGA,KAlCA;AAmCA,IAAA,QAnCA,oBAmCA,IAnCA,EAmCA;AACA,WAAA,WAAA,GAAA,IAAA;AACA,WAAA,KAAA,CAAA,WAAA,GAAA,IAAA;AACA;AAtCA;AAlCA,CAAA","sourcesContent":["<template>\r\n  <div class=\"tags-wrapper\" :class=\"recoShow?'reco-show': 'reco-hide'\">\r\n    <Common :sidebar=\"false\" :isComment=\"false\">\r\n      <TagList :currentTag=\"currentTag\" @getCurrentTag=\"tagClick\"></TagList>\r\n      <note-abstract\r\n        class=\"list\"\r\n        :data=\"posts\"\r\n        :currentPage=\"currentPage\"\r\n        :currentTag=\"currentTag\"\r\n        @currentTag=\"getCurrentTag\"></note-abstract>\r\n\r\n      <pagation\r\n        class=\"pagation\"\r\n        :total=\"posts.length\"\r\n        :currentPage=\"currentPage\"\r\n        @getCurrentPage=\"getCurrentPage\"></pagation>\r\n    </Common>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Common from '@theme/components/Common.vue'\r\nimport TagList from '@theme/components/TagList.vue'\r\nimport NoteAbstract from '@theme/components/NoteAbstract.vue'\r\nimport mixin from '@theme/mixins/index.js'\r\n\r\nexport default {\r\n  mixins: [mixin],\r\n  components: { Common, NoteAbstract, TagList },\r\n  data () {\r\n    return {\r\n      posts: [],\r\n      tags: [],\r\n      currentTag: '全部',\r\n      currentPage: 1,\r\n      recoShow: false,\r\n      allTagName: '全部'\r\n    }\r\n  },\r\n  computed: {\r\n    // 时间降序后的博客列表\r\n    handlePosts () {\r\n      let posts = this.$site.pages\r\n      posts = this._filterPostData(posts)\r\n      this._sortPostData(posts)\r\n      return posts\r\n    }\r\n  },\r\n  created () {\r\n    if (this.$tags.list.length > 0) {\r\n      const currentTag = this.$route.query.tag ? this.$route.query.tag : this.currentTag\r\n\r\n      this.getPagesByTags(currentTag)\r\n    }\r\n  },\r\n\r\n  mounted () {\r\n    this.recoShow = true\r\n  },\r\n\r\n  methods: {\r\n\r\n    async tagClick (currentTag) {\r\n      await this.getPagesByTags(currentTag)\r\n      window.scrollTo(0, 0)\r\n    },\r\n\r\n    // 根据分类获取页面数据\r\n    getPagesByTags (currentTag) {\r\n      this.currentTag = currentTag\r\n\r\n      let posts = []\r\n      if (currentTag !== '全部') {\r\n        posts = this.$tags.map[currentTag].pages\r\n        this._sortPostData(posts)\r\n      } else {\r\n        posts = this.handlePosts\r\n      }\r\n\r\n      // reverse()是为了按时间最近排序排序\r\n      this.posts = posts.length == 0 ? [] : posts\r\n\r\n      this._setPage(1)\r\n    },\r\n\r\n    getCurrentTag (tag) {\r\n      this.$emit('currentTag', tag)\r\n    },\r\n\r\n    getCurrentPage (page) {\r\n      this._setPage(page)\r\n      setTimeout(() => {\r\n        window.scrollTo(0, 0)\r\n      }, 100)\r\n    },\r\n    _setPage (page) {\r\n      this.currentPage = page\r\n      this.$page.currentPage = page\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style src=\"../styles/theme.styl\" lang=\"stylus\"></style>\r\n\r\n<style lang=\"stylus\" scoped>\r\n@require '../styles/loadMixin.styl'\r\n.tags-wrapper\r\n  max-width: 740px;\r\n  margin: 0 auto;\r\n  padding: 4.6rem 2.5rem 0;\r\n  &.reco-hide {\r\n    .tags, .list, .pagation {\r\n      load-start()\r\n    }\r\n  }\r\n  &.reco-show {\r\n    .tags {\r\n      load-end(0.08s)\r\n    }\r\n    .list {\r\n      load-end(0.16s)\r\n    }\r\n    .pagation {\r\n      load-end(0.24s)\r\n    }\r\n  }\r\n\r\n@media (max-width: $MQMobile)\r\n  .tags-wrapper\r\n    padding: 5rem 0.6rem 0;\r\n</style>\r\n"],"sourceRoot":"node_modules/vuepress-theme-reco/layouts"}]}